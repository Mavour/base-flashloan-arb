# ════════════════════════════════════════════════
# BASE FLASHLOAN ARB BOT
# cp .env.example .env → isi semua field
# JANGAN commit .env ke GitHub!
# ════════════════════════════════════════════════

# ─── WALLET ───
# Private key wallet DEDICATED (bukan wallet utama!)
# Format: hex tanpa 0x prefix, atau dengan 0x
WALLET_PRIVATE_KEY=your_private_key_here

# ─── RPC ───
# Daftar gratis di https://alchemy.com
# Pilih "Create App" → Base → Mainnet
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── CONTRACT ───
# Diisi setelah deploy (npm run deploy)
ARBITRAGE_CONTRACT_ADDRESS=

# ─── BASESCAN (opsional, untuk verify contract) ───
# Daftar di https://basescan.org/apis
BASESCAN_API_KEY=

# ════════════════════════════════════════════════
# PARAMETER BOT
# ════════════════════════════════════════════════

# Interval scan (ms) — default 2 detik
SCAN_INTERVAL_MS=2000

# Minimum profit ETH sebelum eksekusi
# 0.0005 ETH ≈ $1.25
MIN_PROFIT_ETH=0.0005

# Ukuran flashloan dalam ETH
# Lebih besar = profit absolut lebih besar
FLASHLOAN_AMOUNT_ETH=10

# Priority fee (gwei) — untuk speed di Base
MAX_PRIORITY_FEE_GWEI=0.1

# DRY RUN — selalu true dulu!
DRY_RUN=true

# ════════════════════════════════════════════════
# TELEGRAM (opsional)
# ════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ════════════════════════════════════════════════
# HEALTH CHECK
# ════════════════════════════════════════════════
HEALTHCHECK_PORT=3001
